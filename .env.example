# Database (SQLite path inside container or local dev)
DATABASE_URL=sqlite:///data/gpuindex.db

# Scheduler
COLLECTOR_INTERVAL_MINUTES=60
LOG_LEVEL=INFO

# Provider API keys (Phase 1+; collectors degrade gracefully without keys)
# RUNPOD_API_KEY=   # optional; RunPod public GraphQL works without a key
# LAMBDA_API_KEY=   # required for live Lambda capacity/pricing API

# Contact info for User-Agent header
CONTACT_EMAIL=ops@example.com
